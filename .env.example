# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to git!

# Get your ITAD API key from: https://isthereanydeal.com/apps/my/
ITAD_API_KEY=your_itad_api_key_here

# Create a bot with @BotFather on Telegram, then copy the token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram chat ID (send /start to @userinfobot to find it)
TELEGRAM_CHAT_ID=your_chat_id_here

# GitHub personal access token (for Vercel to commit changes)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Your repo in "username/repo" format
GITHUB_REPO=yourusername/telegram-game-deals-bot
